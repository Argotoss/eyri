{
  "tasks": {
    "dev": "deno run --watch --env-file=.env -A src/main.ts",
    "format": "deno run -A @biomejs/biome format src --write; deno run -A @biomejs/biome lint src --write"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable"]
  },
  "imports": {
    "@biomejs/biome": "npm:@biomejs/biome@^2.1.3",
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@stoqey/ib": "npm:@stoqey/ib@1.5.5",
    "grammy": "https://deno.land/x/grammy/mod.ts",
    "grammy_types": "https://deno.land/x/grammy_types/mod.ts"
  }
}
