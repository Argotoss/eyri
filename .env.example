TOKEN='telegram-bot-token'
# EYRI_DATABASE_PATH='data/eyri.sqlite'
# EYRI_REPORTS_DIR='data/reports'

# Optional quote providers. Eyri uses configured providers first and falls back
# to Yahoo Chart/Stooq where possible.
# TWELVE_DATA_API_KEY='...'
# FINNHUB_API_KEY='...'
# ALPACA_API_KEY='...'
# ALPACA_API_SECRET='...'

# Optional market intelligence models.
# OPENROUTER_API_KEY='...'
# INTEL_EXTRACT_MODEL='deepseek/deepseek-v4-flash'
# INTEL_REPORT_MODEL='openai/gpt-5.4-mini'

# Optional intelligence scan limits. Defaults are conservative for manual runs.
# INTEL_GDELT_DIRECT_TICKER_LIMIT='5'
# INTEL_GDELT_SP500_FOCUS_LIMIT='8'
# INTEL_GDELT_DELAY_MS='6500'
# INTEL_GDELT_429_BACKOFF_MS='90000'
# INTEL_GDELT_DEEP_MAX_RECORDS='100'
# INTEL_GDELT_MAX_RETRIES='2'
# INTEL_SEC_TICKER_LIMIT='25'
# INTEL_FUNDAMENTAL_TICKER_LIMIT='25'
# INTEL_PRICE_TICKER_LIMIT='60'
# INTEL_ALPACA_NEWS_LIMIT='100'
# INTEL_ALPACA_NEWS_PAGES='2'
# INTEL_FULLTEXT_LIMIT='40'
# INTEL_FULLTEXT_CONCURRENCY='5'
# INTEL_FULLTEXT_TIMEOUT_MS='8000'
# INTEL_DEEP_EXTRACT_ITEM_LIMIT='180'
# INTEL_DEEP_EXTRACT_CHUNK_SIZE='35'
# REDDIT_BEARER_TOKEN='...'
# INTEL_REDDIT_ALLOW_UNAUTH='false'
# SEC_USER_AGENT='Eyri market intelligence your-email@example.com'
