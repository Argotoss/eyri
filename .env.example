# OPENROUTER_API_KEY='...'
# INTEL_EXTRACT_MODEL='deepseek/deepseek-v4-flash'
# INTEL_REPORT_MODEL='openai/gpt-5.4-mini'

# Optional intelligence scan limits. Defaults are conservative for manual runs.
