# INTEL_GDELT_SP500_FOCUS_LIMIT='8'
# INTEL_GDELT_DELAY_MS='6500'
# INTEL_SEC_TICKER_LIMIT='25'
# INTEL_PRICE_TICKER_LIMIT='60'
# SEC_USER_AGENT='Eyri market intelligence your-email@example.com'
